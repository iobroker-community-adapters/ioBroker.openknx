{
  "name": "iobroker.openknx",
  "version": "1.1.6",
  "description": "ioBroker knx Adapter",
  "author": "boellner",
  "contributors": [
    "iobroker-community-adapters <iobroker-community-adapters@gmx.de>"
  ],
  "homepage": "https://github.com/iobroker-community-adapters/ioBroker.openknx.git",
  "license": "GPL-3.0-only",
  "keywords": [
    "ioBroker",
    "knx",
    "KNX IP Gateway",
    "connex",
    "instabus",
    "eib",
    "ets",
    "ets4",
    "ets5",
    "ets6",
    "bus",
    "communication",
    "Kommunikation",
    "Smart Home",
    "home automation",
    "Heimautomatisierung"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iobroker-community-adapters/ioBroker.openknx"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@xmldom/xmldom": "^0.9.10",
    "@zip.js/zip.js": "^2.8.26",
    "ipaddr.js": "^2.3.0",
    "knxultimate": "^5.5.2",
    "sax": "^1.6.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.6.0",
    "typescript": "~5.9.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "prebuild": "rimraf admin/build",
    "build": "build-adapter",
    "watch": "build-adapter --watch",
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js,test/**/*.test.js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/iobroker-community-adapters/ioBroker.openknx/issues"
  },
  "readmeFilename": "README.md"
}
